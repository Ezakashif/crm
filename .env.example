APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Must match the URL you open in the browser (include port), e.g. http://localhost:8000
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Set true behind HTTPS in production
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Default "log" writes mail to storage/logs — it does NOT reach inboxes.
# Local inbox: run Mailpit (or similar) and use:
#   MAIL_MAILER=smtp
#   MAIL_HOST=127.0.0.1
#   MAIL_PORT=1025
# Gmail (App Password required):
#   MAIL_MAILER=smtp
#   MAIL_HOST=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_SCHEME=null
#   MAIL_USERNAME=you@gmail.com
#   MAIL_PASSWORD="your app password"
#   MAIL_FROM_ADDRESS=you@gmail.com   # should match MAIL_USERNAME (or a Gmail "Send mail as" alias)
# Auth emails (verification / password reset) send immediately (no queue worker required).
# Production: smtp / ses / postmark / resend with real credentials.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Lead follow-up reminders (email + in-app notifications)
LEAD_FOLLOW_UP_REMINDERS_ENABLED=true
LEAD_FOLLOW_UP_REMINDER_TIME=08:00
LEAD_FOLLOW_UP_DEFAULT_TIME=09:00
LEAD_FOLLOW_UP_REMINDER_1D_ENABLED=true
LEAD_FOLLOW_UP_REMINDER_2H_ENABLED=true
LEAD_FOLLOW_UP_REMINDER_DUE_ENABLED=true
LEAD_FOLLOW_UP_REMINDER_OVERDUE_ENABLED=true
LEAD_FOLLOW_UP_REMINDER_OVERDUE_REPEAT_DAYS=1

# Task due and overdue reminders (in-app notifications)
TASK_REMINDERS_ENABLED=true
TASK_REMINDER_TIME=08:15
TASK_REMINDER_DUE_ENABLED=true
TASK_REMINDER_OVERDUE_ENABLED=true
TASK_REMINDER_OVERDUE_REPEAT_DAYS=1

# Website form webhook (server-to-server only; never expose the secret in browser JS)
WEBSITE_LEAD_WEBHOOK_SECRET=
WEBSITE_LEAD_CREATED_BY_EMAIL=admin@example.com
WEBSITE_LEAD_RATE_LIMIT=10
